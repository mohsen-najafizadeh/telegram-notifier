{
    "name": "php/mini-php-app",
    "type": "project",
    "description": "minimal php app",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "mohsen-najafizadeh/telegram-notifier": "^1.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
